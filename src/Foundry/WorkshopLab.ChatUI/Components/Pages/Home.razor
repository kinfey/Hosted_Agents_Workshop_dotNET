@page "/"
@rendermode InteractiveServer
@using WorkshopLab.ChatUI.Services
@inject FoundryAgentClient AgentClient

<PageTitle>Hosted Agent Chat UI</PageTitle>

<h1>Hosted Agent Chat UI</h1>

<p>Use this page to send real prompts to your deployed Foundry hosted agent.</p>

<div class="chat-shell">
	<div class="chat-log">
		@foreach (var message in _messages)
		{
			<div class="chat-item @(message.IsUser ? "user" : "assistant")">
				<div class="role">@message.Role</div>
				<div class="text">@message.Text</div>
			</div>
		}
	</div>

	<div class="composer">
		<textarea @bind="_prompt"
				  rows="4"
				  placeholder="Ask your hosted agent about implementation shape, readiness, or troubleshooting..."></textarea>
		<button @onclick="SendAsync" disabled="@_isSending">@(_isSending ? "Sending..." : "Send Prompt")</button>
	</div>

	@if (!string.IsNullOrWhiteSpace(_error))
	{
		<div class="error">@_error</div>
	}
</div>

@code {
	private readonly List<ChatLine> _messages =
	[
		new ChatLine(false, "Assistant", "Ready. Ask me whether your scenario should use a hosted agent.")
	];

	private string _prompt =
		"We are onboarding a team to Microsoft Foundry hosted agents. We need private API access, a repeatable deployment process, and a launch checklist for production readiness. Should we use a hosted agent for this scenario, and what implementation shape do you recommend?";
	private string _error = string.Empty;
	private bool _isSending;

	private async Task SendAsync()
	{
		if (_isSending || string.IsNullOrWhiteSpace(_prompt))
		{
			return;
		}

		_error = string.Empty;
		var prompt = _prompt.Trim();
		_messages.Add(new ChatLine(true, "You", prompt));
		_prompt = string.Empty;
		_isSending = true;

		try
		{
			var reply = await AgentClient.SendAsync(prompt);
			_messages.Add(new ChatLine(false, "Assistant", reply));
		}
		catch (Exception ex)
		{
			_error = ex.Message;
		}
		finally
		{
			_isSending = false;
		}
	}

	private sealed record ChatLine(bool IsUser, string Role, string Text);
}

<style>
	.chat-shell {
		display: grid;
		gap: 1rem;
		max-width: 920px;
	}

	.chat-log {
		background: #f8fafc;
		border: 1px solid #cbd5e1;
		border-radius: 10px;
		min-height: 320px;
		max-height: 520px;
		overflow: auto;
		padding: 1rem;
		display: grid;
		gap: 0.75rem;
	}

	.chat-item {
		padding: 0.75rem;
		border-radius: 10px;
		line-height: 1.4;
	}

	.chat-item.user {
		background: #dbeafe;
		border: 1px solid #93c5fd;
	}

	.chat-item.assistant {
		background: #ecfdf5;
		border: 1px solid #6ee7b7;
	}

	.role {
		font-size: 0.8rem;
		font-weight: 700;
		text-transform: uppercase;
		margin-bottom: 0.35rem;
	}

	.text {
		white-space: pre-wrap;
	}

	.composer {
		display: grid;
		gap: 0.5rem;
	}

	.composer textarea {
		width: 100%;
		border-radius: 10px;
		border: 1px solid #94a3b8;
		padding: 0.75rem;
		font-family: inherit;
	}

	.composer button {
		width: fit-content;
		border: none;
		border-radius: 8px;
		padding: 0.6rem 1rem;
		background: #0f766e;
		color: white;
		cursor: pointer;
		font-weight: 600;
	}

	.composer button:disabled {
		background: #64748b;
		cursor: not-allowed;
	}

	.error {
		color: #991b1b;
		background: #fee2e2;
		border: 1px solid #fecaca;
		border-radius: 8px;
		padding: 0.6rem;
	}
</style>
